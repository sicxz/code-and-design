---
import '../styles/styles.css';
import Icon from '../components/Icon.astro';
import { getCourseFromPathname } from '../lib/courseRegistry';

const { title = 'code-and-design.org' } = Astro.props;
const course = getCourseFromPathname(Astro.url.pathname);
const footerYear = course?.term.match(/20\d{2}/)?.[0] ?? '2026';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=DM+Mono:wght@400;500&display=swap"
        rel="stylesheet"
    />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="code+design" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Import your existing CSS -->
    <!-- CSS is automatcially injected by the import -->

</head>
<body data-course={course?.themeId ?? 'home'}>
    <!-- Mobile Notice Banner -->
    <div id="mobile-notice" class="mobile-notice">
        <div class="mobile-notice-content">
            <span class="mobile-notice-text">
                📱 Best viewed on desktop. Mobile navigation available at bottom.
            </span>
            <button class="mobile-notice-close" onclick="dismissNotice()" aria-label="Dismiss notice">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor">
                    <path d="M6.697 6l3.849-3.849a.5.5 0 1 0-.707-.707L6 5.293 2.151 1.444a.5.5 0 1 0-.707.707L5.293 6 1.444 9.849a.5.5 0 1 0 .707.707L6 6.707l3.849 3.849a.5.5 0 1 0 .707-.707L6.707 6z"/>
                </svg>
            </button>
        </div>
    </div>

    <header class="course-header">
        <div class="header-container">
            <div class="header-top">
                <div class="course-title-group">
                    <div class="course-icon">
                        <Icon name="book" size={32} class="course-title-icon" />
                    </div>
                    <div>
                        <h1 class="course-title">
                            {course ? course.title : 'code-and-design.org'}
                            <span class="course-badge">
                                <Icon name="zap" size={14} class="badge-icon" />
                                {course ? course.term : 'Unified Hub'}
                            </span>
                        </h1>
                        <p class="course-subtitle">
                            {course
                                ? course.subtitle
                                : 'Two course sites, one domain, one Astro app.'}
                        </p>
                    </div>
                </div>
                <div class="header-actions">
                    {course ? (
                        <>
                            <a href="/" class="btn-fork">All Courses</a>
                            <a href={course.canvasUrl} class="btn-fork" target="_blank">Canvas</a>
                            <a href={course.milanoteUrl} class="btn btn-start" target="_blank">Milanote</a>
                        </>
                    ) : (
                        <>
                            <a href="/1" class="btn-fork">Open /1</a>
                            <a href="/2" class="btn btn-start">Open /2</a>
                        </>
                    )}
                </div>
            </div>
            <div class="course-meta">
                {course ? (
                    <>
                        <span class="meta-item">
                            <svg width="16" height="16" fill="none" stroke="var(--brand-primary)" viewBox="0 0 24 24" style="margin-right: 6px;">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/>
                            </svg>
                            {course.studentCount}
                        </span>
                        <span class="meta-item">
                            <svg width="16" height="16" fill="none" stroke="var(--brand-red)" viewBox="0 0 24 24" style="margin-right: 6px;">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2v0M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/>
                            </svg>
                            {course.weekCount} weeks
                        </span>
                        <span class="meta-item">
                            <svg width="16" height="16" fill="none" stroke="var(--text-muted)" viewBox="0 0 24 24" style="margin-right: 6px;">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            {course.workload}
                        </span>
                    </>
                ) : (
                    <>
                        <span class="meta-item">2 course hubs</span>
                        <span class="meta-item">Shared components + layout</span>
                        <span class="meta-item">Single Astro deployment</span>
                    </>
                )}
            </div>
        </div>
    </header>


    <!-- This is where page content goes -->
    <slot />

    <!-- Footer -->
    <footer class="site-footer">
        <div class="footer-container">
            <div class="footer-content">
                <div class="footer-brand">
                    <span class="footer-title">{course ? course.title : 'code-and-design.org'}</span>
                    <span class="footer-subtitle">Eastern Washington University</span>
                </div>
                <div class="footer-links">
                    {course ? (
                        <>
                            <a href="/">All Courses</a>
                            <a href={course.homePath}>Overview</a>
                            <a href={course.syllabusPath}>Syllabus</a>
                            <a href={course.assignmentsPath}>Assignments</a>
                            {course.styleGuidePath && <a href={course.styleGuidePath}>Style Guide</a>}
                            <a href={course.repoUrl} target="_blank">GitHub</a>
                        </>
                    ) : (
                        <>
                            <a href="/1">Code + Design 1</a>
                            <a href="/2">Code + Design 2</a>
                            <a href="/1/assignments">Course 1 Assignments</a>
                            <a href="/2/assignments">Course 2 Assignments</a>
                        </>
                    )}
                </div>
            </div>
            <div class="footer-bottom">
                <span>© {footerYear} Travis Masingale</span>
                <span class="footer-divider">·</span>
                <span>{course ? course.term : 'Shared course hub'}</span>
            </div>
        </div>
    </footer>

    <script>
        // Quick Reference toggle functionality
        function toggleReference(section) {
            const content = document.getElementById(section + '-content');
            const chevron = document.getElementById(section + '-chevron');

            if (content.classList.contains('expanded')) {
                content.classList.remove('expanded');
                chevron.classList.remove('rotated');
            } else {
                content.classList.add('expanded');
                chevron.classList.add('rotated');
            }
        }

        // Mobile notice dismiss functionality
        function dismissNotice() {
            const notice = document.getElementById('mobile-notice');
            notice.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
            notice.style.opacity = '0';
            notice.style.transform = 'translateY(-100%)';

            setTimeout(() => {
                notice.style.display = 'none';
            }, 300);

            // Remember user preference
            localStorage.setItem('mobileNoticeDismissed', 'true');
        }

        // Check if notice was previously dismissed
        document.addEventListener('DOMContentLoaded', function() {
            if (localStorage.getItem('mobileNoticeDismissed') === 'true') {
                const notice = document.getElementById('mobile-notice');
                notice.style.display = 'none';
            }
        });
    </script>
</body>
</html>
