---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Card from '../../../components/Card.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Icon from '../../../components/Icon.astro';
import { readdirSync, readFileSync, statSync, existsSync } from 'node:fs';
import { join, relative, basename } from 'node:path';
import { marked } from 'marked';
import courseData from '../../../data/course-data.json';

type WeekRecord = {
  week: number;
  route: string;
  title: string;
  unit: string | null;
  interaction_question: string | null;
  summary: string | null;
  learning_outcomes: string[];
  curriculum_files: Record<string, Array<{ title: string; path: string }>>;
  canvas_items: Array<{ title: string; content_type: string; workflow_state: string }>;
};

const { weekData } = Astro.props as { weekData: WeekRecord };

const allWeeks = (courseData.weeks as WeekRecord[]).sort((a, b) => a.week - b.week);
const currentIndex = allWeeks.findIndex((w) => w.week === weekData.week);
const prevWeek = currentIndex > 0 ? allWeeks[currentIndex - 1] : null;
const nextWeek = currentIndex < allWeeks.length - 1 ? allWeeks[currentIndex + 1] : null;

type Doc = {
  id: string;
  title: string;
  category: string;
  relPath: string;
  fileName: string;
  html: string;
};

function walkMarkdown(dir: string): string[] {
  if (!existsSync(dir)) return [];
  const entries = readdirSync(dir);
  const output: string[] = [];
  for (const entry of entries) {
    if (entry.startsWith('_') || entry.startsWith('.')) continue;
    const full = join(dir, entry);
    const stats = statSync(full);
    if (stats.isDirectory()) {
      output.push(...walkMarkdown(full));
      continue;
    }
    if (entry.toLowerCase().endsWith('.md')) output.push(full);
  }
  return output;
}

function slugify(input: string) {
  return input
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)+/g, '');
}

function categoryForPath(relPath: string): string {
  const parts = relPath.split('/');
  if (parts.length === 1) return 'overview';
  return parts[0];
}

marked.setOptions({ gfm: true, breaks: false });

const weekRoot = join(process.cwd(), 'src/content', `week-${weekData.week}`);

const allDocs: Doc[] = walkMarkdown(weekRoot)
  .map((fullPath) => {
    const relPath = relative(weekRoot, fullPath).replaceAll('\\', '/');
    const raw = readFileSync(fullPath, 'utf-8');
    const headingMatch = raw.match(/^#\s+(.+)$/m);
    const title = headingMatch ? headingMatch[1].trim() : basename(relPath, '.md');
    const fileName = basename(relPath);
    const id = slugify(relPath);
    const category = categoryForPath(relPath);
    return { id, title, category, relPath, fileName, html: marked.parse(raw) as string };
  })
  .sort((a, b) => a.relPath.localeCompare(b.relPath));

const categoryOrder = ['overview', 'lectures', 'engage', 'learn', 'practice', 'build', 'reflect', 'resources'];
const categoryLabel: Record<string, string> = {
  overview: 'Overview',
  lectures: 'Lectures',
  engage: 'Engage',
  learn: 'Learn',
  practice: 'Practice',
  build: 'Build',
  reflect: 'Reflect',
  resources: 'Resources',
};

const allCategories = [...new Set(allDocs.map((d) => d.category))];
const orderedCategories = [
  ...categoryOrder.filter((c) => allCategories.includes(c)),
  ...allCategories.filter((c) => !categoryOrder.includes(c)),
];

const groupedDocs = orderedCategories
  .map((category) => ({
    category,
    label: categoryLabel[category] ?? category,
    docs: allDocs.filter((doc) => doc.category === category),
  }))
  .filter((group) => group.docs.length > 0);

const firstDocId = allDocs[0]?.id ?? '';
---

<BaseLayout title={`${weekData.title} - DESN378`}>
  <nav class="breadcrumb-nav">
    <div class="breadcrumb-container">
      <div class="breadcrumb">
        <a href="/2">Course Overview</a>
        <span class="breadcrumb-separator">></span>
        <span class="breadcrumb-current">Week {weekData.week}: {weekData.title.replace(/^Week \d+:\s*/, '')}</span>
      </div>
    </div>
  </nav>

  <main class="week-browser-layout">
    <aside class="file-browser">
      <div class="browser-head">
        <Icon name="book" size={16} class="section-icon" />
        <span>week-{weekData.week}/</span>
      </div>
      <p class="browser-subtitle">Click a file to open it</p>

      {groupedDocs.length > 0 ? (
        <div class="tree">
          {groupedDocs.map((group) => (
            <details open>
              <summary>{group.label}/</summary>
              <ul>
                {group.docs.map((doc) => (
                  <li>
                    <a href={`#${doc.id}`} data-doc={doc.id}>
                      <span class="entry-title">{doc.title}</span>
                      <span class="entry-file">{doc.fileName}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ))}
        </div>
      ) : (
        <p class="browser-empty">No content files yet.</p>
      )}

      <div class="week-nav-links">
        {prevWeek ? (
          <a href={prevWeek.route}>← Week {prevWeek.week}</a>
        ) : (
          <span class="nav-disabled">Start of course</span>
        )}
        {nextWeek ? (
          <a href={nextWeek.route}>Week {nextWeek.week} →</a>
        ) : (
          <span class="nav-disabled">Final week</span>
        )}
      </div>
    </aside>

    <div class="week-content">
      {/* Week header — always visible */}
      <Card variant="accent" class="card-enhanced week-header-card">
        <SectionHeader level={1} icon="calendar" badge={{ text: `Week ${weekData.week}`, variant: 'info' }}>
          {weekData.title}
        </SectionHeader>
        {weekData.unit && <p class="subtitle"><strong>Unit:</strong> {weekData.unit}</p>}
        {weekData.interaction_question && <p class="subtitle">{weekData.interaction_question}</p>}
      </Card>

      {/* All doc panels — only one shown at a time via JS */}
      <div class="doc-viewer">
        {allDocs.length === 0 && (
          <div class="doc-empty">
            <p>Content for this week is coming soon.</p>
          </div>
        )}

        {allDocs.map((doc) => (
          <article id={doc.id} class="doc-panel" hidden>
            <header class="doc-header">
              <h2>{doc.title}</h2>
              <code>{doc.relPath}</code>
            </header>
            <div class="markdown-view" set:html={doc.html}></div>
          </article>
        ))}
      </div>
    </div>
  </main>

  <script define:vars={{ firstDocId }}>
    const panels = document.querySelectorAll('.doc-panel');
    const links = document.querySelectorAll('.file-browser a[data-doc]');

    function showDoc(id) {
      panels.forEach((p) => { p.hidden = true; });
      links.forEach((l) => l.classList.remove('active'));

      const panel = document.getElementById(id);
      const link = document.querySelector(`.file-browser a[data-doc="${id}"]`);
      if (panel) panel.hidden = false;
      if (link) link.classList.add('active');
    }

    // Restore from URL hash or default to first doc
    const hash = location.hash.slice(1);
    showDoc(hash && document.getElementById(hash) ? hash : firstDocId);

    links.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const id = link.dataset.doc;
        showDoc(id);
        history.pushState(null, '', '#' + id);
      });
    });
  </script>

  <style>
    .week-browser-layout {
      max-width: 1360px;
      margin: 0 auto;
      padding: 1.25rem 1.25rem 3rem;
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 1rem;
    }

    .file-browser {
      position: sticky;
      top: 1rem;
      align-self: start;
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 0.95rem 0.9rem;
      max-height: calc(100vh - 2rem);
      overflow: auto;
    }

    .browser-head {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-weight: 600;
      color: var(--text-primary);
      font-size: 0.9rem;
    }

    .browser-subtitle {
      margin: 0.3rem 0 0.75rem;
      color: var(--text-muted);
      font-size: 0.75rem;
      font-style: italic;
    }

    .browser-empty {
      color: var(--text-muted);
      font-size: 0.85rem;
      margin-bottom: 1rem;
    }

    .tree details {
      margin-bottom: 0.45rem;
    }

    .tree summary {
      cursor: pointer;
      color: var(--text-secondary);
      font-size: 0.82rem;
      font-weight: 600;
      list-style: none;
      padding: 0.2rem 0.3rem;
      border-radius: 4px;
    }

    .tree summary::-webkit-details-marker {
      display: none;
    }

    .tree summary:hover {
      color: var(--text-primary);
    }

    .tree ul {
      list-style: none;
      margin: 0.25rem 0 0.35rem 0.65rem;
      padding: 0;
      border-left: 1px dashed var(--border-color);
    }

    .tree li {
      margin: 0;
      padding: 0;
    }

    .tree a {
      display: block;
      padding: 0.25rem 0.45rem;
      text-decoration: none;
      font-size: 0.78rem;
      border-radius: 6px;
      overflow-wrap: anywhere;
      border-left: 2px solid transparent;
      transition: background 0.1s, border-color 0.1s;
    }

    .tree a:hover {
      background: var(--bg-tertiary);
    }

    .tree a:hover .entry-title {
      color: var(--text-primary);
    }

    .tree a.active {
      background: var(--bg-tertiary);
      border-left-color: var(--brand-primary);
    }

    .tree a.active .entry-title {
      color: var(--text-primary);
      font-weight: 600;
    }

    .entry-title {
      display: block;
      color: var(--text-secondary);
      font-size: 0.78rem;
      line-height: 1.25;
      margin-bottom: 0.1rem;
    }

    .entry-file {
      display: block;
      color: var(--text-muted);
      font-size: 0.68rem;
      line-height: 1.2;
    }

    .week-nav-links {
      display: grid;
      gap: 0.5rem;
      margin-top: 1rem;
      padding-top: 0.75rem;
      border-top: 1px solid var(--border-color);
    }

    .week-nav-links a {
      color: var(--text-link);
      text-decoration: none;
      font-size: 0.8rem;
    }

    .week-nav-links a:hover {
      text-decoration: underline;
    }

    .nav-disabled {
      color: var(--text-muted);
      font-size: 0.8rem;
    }

    .week-content {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .week-header-card {
      flex-shrink: 0;
    }

    .subtitle {
      margin-top: 0.4rem;
      color: var(--text-secondary);
    }

    .doc-viewer {
      flex: 1;
    }

    .doc-empty {
      background: var(--bg-card);
      border: 1px solid var(--border-light);
      border-radius: 10px;
      padding: 1.5rem;
      color: var(--text-secondary);
    }

    .doc-panel {
      background: var(--bg-card);
      border: 1px solid var(--border-light);
      border-radius: 10px;
      padding: 1.25rem 1.5rem;
    }

    .doc-header {
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--border-color);
    }

    .doc-header h2 {
      margin: 0 0 0.3rem 0;
      color: var(--text-primary);
      font-size: 1.2rem;
    }

    .doc-header code {
      color: var(--text-muted);
      font-size: 0.75rem;
      word-break: break-word;
    }

    .markdown-view {
      color: var(--text-secondary);
      line-height: 1.7;
    }

    .markdown-view :global(h1),
    .markdown-view :global(h2),
    .markdown-view :global(h3),
    .markdown-view :global(h4) {
      color: var(--text-primary);
      margin-top: 1.25rem;
      margin-bottom: 0.5rem;
    }

    .markdown-view :global(h1:first-child),
    .markdown-view :global(h2:first-child) {
      margin-top: 0;
    }

    .markdown-view :global(p) {
      margin: 0.5rem 0;
    }

    .markdown-view :global(ul),
    .markdown-view :global(ol) {
      margin: 0.4rem 0 0.6rem 1.2rem;
    }

    .markdown-view :global(li) {
      margin: 0.25rem 0;
    }

    .markdown-view :global(pre) {
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 0.75rem 1rem;
      overflow-x: auto;
      margin: 0.75rem 0;
    }

    .markdown-view :global(code) {
      font-family: var(--font-mono);
      font-size: 0.85em;
    }

    .markdown-view :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 0.75rem 0;
      font-size: 0.9rem;
    }

    .markdown-view :global(th),
    .markdown-view :global(td) {
      border: 1px solid var(--border-color);
      padding: 0.5rem 0.6rem;
      vertical-align: top;
    }

    .markdown-view :global(th) {
      background: var(--bg-tertiary);
      color: var(--text-primary);
      font-weight: 600;
    }

    .markdown-view :global(blockquote) {
      border-left: 3px solid var(--brand-primary);
      margin: 0.75rem 0;
      padding: 0.5rem 1rem;
      background: var(--bg-tertiary);
      border-radius: 0 6px 6px 0;
    }

    .markdown-view :global(a) {
      color: var(--text-link);
    }

    .markdown-view :global(hr) {
      border: none;
      border-top: 1px solid var(--border-color);
      margin: 1rem 0;
    }

    @media (max-width: 980px) {
      .week-browser-layout {
        grid-template-columns: 1fr;
      }

      .file-browser {
        position: static;
        max-height: none;
      }
    }
  </style>
</BaseLayout>
