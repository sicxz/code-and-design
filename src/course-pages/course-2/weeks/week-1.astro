---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Card from '../../../components/Card.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Icon from '../../../components/Icon.astro';
import { readdirSync, readFileSync, statSync } from 'node:fs';
import { join, relative, basename } from 'node:path';
import { marked } from 'marked';

type Doc = {
  id: string;
  title: string;
  category: string;
  relPath: string;
  fileName: string;
  html: string;
};

const weekRoot = join(process.cwd(), 'src/content/week-1');

function walkMarkdown(dir: string): string[] {
  const entries = readdirSync(dir);
  const output: string[] = [];
  for (const entry of entries) {
    const full = join(dir, entry);
    const stats = statSync(full);
    if (stats.isDirectory()) {
      output.push(...walkMarkdown(full));
      continue;
    }
    if (entry.toLowerCase().endsWith('.md')) output.push(full);
  }
  return output;
}

function slugify(input: string) {
  return input
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)+/g, '');
}

function categoryForPath(relPath: string): string {
  const first = relPath.split('/')[0];
  if (first === 'week-1-overview.md') return 'overview';
  if (first === 'WEEK-1-WALKTHROUGH.md') return 'walkthrough';
  if (first === 'desn378-wk-1-details.md') return 'details';
  if (first === '_instructor-notes') return 'instructor-notes';
  return first;
}

marked.setOptions({
  gfm: true,
  breaks: false,
});

const allDocs: Doc[] = walkMarkdown(weekRoot)
  .map((fullPath) => {
    const relPath = relative(weekRoot, fullPath).replaceAll('\\', '/');
    const raw = readFileSync(fullPath, 'utf-8');
    const headingMatch = raw.match(/^#\s+(.+)$/m);
    const title = headingMatch ? headingMatch[1].trim() : basename(relPath, '.md');
    const fileName = basename(relPath);
    const id = slugify(relPath);
    const category = categoryForPath(relPath);

    return {
      id,
      title,
      category,
      relPath,
      fileName,
      html: marked.parse(raw) as string,
    };
  })
  .filter((doc) => doc.category !== 'instructor-notes')
  .sort((a, b) => a.relPath.localeCompare(b.relPath));

const categoryOrder = ['overview', 'lectures', 'engage', 'learn', 'practice', 'build', 'reflect', 'resources', 'walkthrough', 'details'];
const categoryLabel: Record<string, string> = {
  overview: 'Overview',
  lectures: 'Lectures',
  engage: 'Engage',
  learn: 'Learn',
  practice: 'Practice',
  build: 'Build',
  reflect: 'Reflect',
  resources: 'Resources',
  walkthrough: 'Walkthrough',
  details: 'Details',
};

const groupedDocs = categoryOrder
  .map((category) => ({
    category,
    label: categoryLabel[category] ?? category,
    docs: allDocs.filter((doc) => doc.category === category),
  }))
  .filter((group) => group.docs.length > 0);
---

<BaseLayout title="Week 1: First Light - DESN378">
  <nav class="breadcrumb-nav">
    <div class="breadcrumb-container">
      <div class="breadcrumb">
        <a href="/2">Course Overview</a>
        <span class="breadcrumb-separator">></span>
        <span class="breadcrumb-current">Week 1: First Light</span>
      </div>
    </div>
  </nav>

  <main class="week-browser-layout">
    <aside class="file-browser">
      <div class="browser-head">
        <Icon name="book" size={16} class="section-icon" />
        <span>week-1/</span>
      </div>
      <p class="browser-subtitle">Pretend file browser</p>
      <div class="tree">
        {groupedDocs.map((group) => (
          <details open>
            <summary>{group.label}/</summary>
            <ul>
              {group.docs.map((doc) => (
                <li>
                  <a href={`#${doc.id}`}>
                    <span class="entry-title">{doc.title}</span>
                    <span class="entry-file">{doc.fileName}</span>
                  </a>
                </li>
              ))}
            </ul>
          </details>
        ))}
      </div>
    </aside>

    <div class="week-content">
      <Card variant="accent" class="card-enhanced">
        <SectionHeader level={1} icon="calendar" badge={{ text: 'Week 1', variant: 'success' }}>
          Week 1: First Light
        </SectionHeader>
        <p class="subtitle">
          Full Week 1 assignment content pulled into the site. Click files in the sidebar to jump directly to each assignment.
        </p>
      </Card>

      {groupedDocs.map((group) => (
        <section class="category-section">
          <h2>{group.label}</h2>
          {group.docs.map((doc) => (
            <article id={doc.id} class="doc-panel">
              <header class="doc-header">
                <h3>{doc.title}</h3>
                <code>{doc.relPath}</code>
              </header>
              <div class="markdown-view" set:html={doc.html}></div>
            </article>
          ))}
        </section>
      ))}
    </div>
  </main>

  <style>
    .week-browser-layout {
      max-width: 1360px;
      margin: 0 auto;
      padding: 1.25rem 1.25rem 3rem;
      display: grid;
      grid-template-columns: 300px 1fr;
      gap: 1rem;
    }

    .file-browser {
      position: sticky;
      top: 1rem;
      align-self: start;
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 0.95rem 0.9rem;
      max-height: calc(100vh - 2rem);
      overflow: auto;
    }

    .browser-head {
      display: flex;
      align-items: center;
      font-weight: 600;
      color: var(--text-primary);
    }

    .browser-subtitle {
      margin: 0.3rem 0 0.75rem;
      color: var(--text-muted);
      font-size: 0.8rem;
    }

    .tree details {
      margin-bottom: 0.45rem;
    }

    .tree summary {
      cursor: pointer;
      color: var(--text-secondary);
      font-size: 0.88rem;
      font-weight: 600;
      list-style: none;
    }

    .tree summary::-webkit-details-marker {
      display: none;
    }

    .tree ul {
      list-style: none;
      margin: 0.35rem 0 0.45rem 0.65rem;
      padding: 0;
      border-left: 1px dashed var(--border-color);
    }

    .tree li {
      margin: 0;
      padding: 0;
    }

    .tree a {
      display: block;
      padding: 0.2rem 0.45rem;
      color: var(--text-link);
      text-decoration: none;
      font-size: 0.78rem;
      border-radius: 6px;
      overflow-wrap: anywhere;
    }

    .entry-title {
      display: block;
      color: var(--text-secondary);
      font-size: 0.78rem;
      line-height: 1.25;
      margin-bottom: 0.15rem;
    }

    .entry-file {
      display: block;
      color: var(--text-muted);
      font-size: 0.69rem;
      line-height: 1.2;
    }

    .tree a:hover {
      background: var(--bg-tertiary);
    }

    .tree a:hover .entry-title {
      color: var(--text-primary);
    }

    .week-content {
      min-width: 0;
    }

    .subtitle {
      margin-top: 0.5rem;
      color: var(--text-secondary);
    }

    .category-section {
      margin-top: 1rem;
    }

    .category-section h2 {
      color: var(--text-primary);
      margin: 0 0 0.65rem 0;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.4rem;
    }

    .doc-panel {
      background: var(--bg-card);
      border: 1px solid var(--border-light);
      border-radius: 10px;
      padding: 0.9rem 1rem;
      margin-bottom: 0.9rem;
    }

    .doc-header h3 {
      margin: 0 0 0.25rem 0;
      color: var(--text-primary);
      font-size: 1.05rem;
    }

    .doc-header code {
      color: var(--text-muted);
      font-size: 0.75rem;
      word-break: break-word;
    }

    .markdown-view {
      margin-top: 0.8rem;
      color: var(--text-secondary);
      line-height: 1.65;
    }

    .markdown-view :global(h1),
    .markdown-view :global(h2),
    .markdown-view :global(h3),
    .markdown-view :global(h4) {
      color: var(--text-primary);
      margin-top: 1rem;
      margin-bottom: 0.45rem;
    }

    .markdown-view :global(p) {
      margin: 0.45rem 0;
    }

    .markdown-view :global(ul),
    .markdown-view :global(ol) {
      margin: 0.4rem 0 0.6rem 1.2rem;
    }

    .markdown-view :global(li) {
      margin: 0.2rem 0;
    }

    .markdown-view :global(pre) {
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 0.7rem;
      overflow-x: auto;
    }

    .markdown-view :global(code) {
      font-family: var(--font-mono);
      font-size: 0.85em;
    }

    .markdown-view :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 0.7rem 0;
      font-size: 0.9rem;
    }

    .markdown-view :global(th),
    .markdown-view :global(td) {
      border: 1px solid var(--border-color);
      padding: 0.45rem 0.5rem;
      vertical-align: top;
    }

    .markdown-view :global(a) {
      color: var(--text-link);
    }

    @media (max-width: 980px) {
      .week-browser-layout {
        grid-template-columns: 1fr;
      }

      .file-browser {
        position: static;
        max-height: none;
      }
    }
  </style>
</BaseLayout>
