---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Card from '../../../components/Card.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Icon from '../../../components/Icon.astro';

type Project = {
  slug: string;
  title: string;
  path?: string;
  checklist?: string;
};

const { project } = Astro.props as { project: Project };
---

<BaseLayout title={`${project.title} - DESN378`}>
  <nav class="breadcrumb-nav">
    <div class="breadcrumb-container">
      <div class="breadcrumb">
        <a href="/2">Course Overview</a>
        <span class="breadcrumb-separator">></span>
        <a href="/2/assignments">Projects + Assignments</a>
        <span class="breadcrumb-separator">></span>
        <span class="breadcrumb-current">{project.title}</span>
      </div>
    </div>
  </nav>

  <main class="course-content two-column">
    <div class="main-content fade-in">
      <Card variant="accent" class="card-enhanced">
        <SectionHeader icon="clipboard-list" level={1} badge={{ text: 'Project', variant: 'success' }}>
          {project.title}
        </SectionHeader>
        <p>
          This detail page keeps the shared `/2/assignments/...` route structure in sync with the
          consolidated curriculum docs already stored in the repo.
        </p>
      </Card>

      <div class="section-divider"></div>

      <Card variant="enhanced">
        <SectionHeader icon="book">
          Canonical Source Files
        </SectionHeader>
        <div class="project-detail-grid">
          {project.path && (
            <div class="detail-block">
              <h3>Brief</h3>
              <code>{project.path}</code>
            </div>
          )}
          {project.checklist && (
            <div class="detail-block">
              <h3>Checklist</h3>
              <code>{project.checklist}</code>
            </div>
          )}
        </div>
      </Card>

      <div class="section-divider"></div>

      <Card variant="accent-subtle" class="card-enhanced">
        <SectionHeader icon="layers">
          Next Step
        </SectionHeader>
        <p>
          Open the project source files in the repo for the full brief and checklist, then use the
          week pages for pacing and day-by-day assignment context.
        </p>
        <p>
          <a href="/2/assignments">← Back to projects + assignments hub</a>
        </p>
      </Card>
    </div>

    <aside class="sidebar">
      <section class="card card-enhanced">
        <h3>
          <Icon name="target" size={18} class="section-icon" />
          Course Context
        </h3>
        <ul class="sidebar-concepts">
          <li>Behavior-first design decisions</li>
          <li>Portfolio work with real deployment expectations</li>
          <li>Use the weekly course routes for pacing</li>
        </ul>
      </section>
    </aside>
  </main>

  <style>
    .project-detail-grid {
      display: grid;
      gap: 0.9rem;
    }

    .detail-block {
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 0.9rem 1rem;
    }

    .detail-block h3 {
      margin-bottom: 0.45rem;
    }

    .detail-block code {
      display: block;
      white-space: pre-wrap;
      word-break: break-word;
      font-size: 0.8rem;
      color: var(--text-secondary);
    }
  </style>
</BaseLayout>
