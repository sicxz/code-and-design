---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';
import Card from '../../../components/Card.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
---

<BaseLayout title="Week 5: CSS Selector Quest - DESN368">
    <nav class="breadcrumb-nav">
        <div class="breadcrumb-container">
            <div class="breadcrumb">
                <a href="/1">Course Overview</a>
                <span class="breadcrumb-separator">></span>
                <span class="breadcrumb-current">Week 5: CSS Selector Quest</span>
            </div>
        </div>
    </nav>

    <main class="course-content two-column">
        <div class="main-content fade-in">
            <Card variant="accent" class="card-enhanced">
                <div class="color-bar color-bar-red"></div>
                <SectionHeader level={1} icon="target" badge={{ text: "Current", variant: "success" }}>
                    Week 5: CSS Selector Quest
                </SectionHeader>
                <p class="subtitle">Spring 2026 · Week 5</p>
                <p>Practice the selectors that make CSS precise: type selectors, class selectors, descendant selectors, pseudo-classes, and semantic layout targets.</p>
            </Card>

            <div class="section-divider"></div>

            <Card variant="enhanced" class="card-enhanced">
                <SectionHeader icon="book" badge={{ text: "This Week", variant: "info" }}>
                    Activity
                </SectionHeader>

                <div class="resource-list">
                    <a href="/1/css-selector-quest/" class="resource-item">
                        <div class="resource-icon">
                            <Icon name="target" size={20} />
                        </div>
                        <div class="resource-body">
                            <div class="resource-title">CSS Selector Quest: The Selector Guild</div>
                            <div class="resource-desc">A full-screen two-panel activity with story chapters, MDN references, and a live CodePen workspace for practicing CSS selectors.</div>
                        </div>
                        <Icon name="link" size={16} class="resource-arrow" />
                    </a>
                </div>
            </Card>
        </div>

        <aside class="sidebar">
            <section class="card card-action card-enhanced">
                <div class="color-bar color-bar-red"></div>
                <h3>
                    <span class="icon-enhanced icon-primary">
                        <Icon name="zap" size={20} />
                    </span>
                    Quick Actions
                </h3>
                <div class="quick-action-stack">
                    <a href="/1" class="btn btn-secondary">
                        <Icon name="book" size={16} class="btn-icon" />
                        Course Overview
                    </a>
                    <a href="/1/css-selector-quest/" class="btn btn-start">
                        <Icon name="target" size={16} class="btn-icon" />
                        Start Selector Quest
                    </a>
                </div>
            </section>
        </aside>
    </main>

    <style>
        .subtitle {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-top: -8px;
            margin-bottom: 16px;
        }

        .resource-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .resource-item {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            padding: 16px;
            border: 1px solid var(--border-subtle);
            border-radius: 8px;
            text-decoration: none;
            color: inherit;
            background: var(--surface-alt);
            transition: border-color 0.15s, background 0.15s;
        }

        .resource-item:hover {
            border-color: var(--brand-primary);
            background: var(--surface);
        }

        .resource-icon {
            flex-shrink: 0;
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--eagle-red-light);
            border-radius: 8px;
            color: var(--eagle-red-text);
        }

        .resource-body {
            flex: 1;
            min-width: 0;
        }

        .resource-title {
            font-weight: 600;
            font-size: 0.95rem;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

        .resource-desc {
            font-size: 0.85rem;
            color: var(--text-secondary);
            line-height: 1.5;
        }

        .resource-arrow {
            flex-shrink: 0;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .quick-action-stack {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
    </style>
</BaseLayout>
