---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';
import Card from '../../../components/Card.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import manifest from '../courseManifest.json';
import { TUTORIALS_BY_WEEK } from '../tutorialsByWeek';

export interface Props {
  week: any; // manifest week object { key, number, title, items[] }
}

const { week } = Astro.props;

const allWeeks = manifest.weeks as any[];
const idx = allWeeks.findIndex((w) => w.key === week.key);
const prev = idx > 0 ? allWeeks[idx - 1] : null;
const next = idx >= 0 && idx < allWeeks.length - 1 ? allWeeks[idx + 1] : null;

// Clean a Canvas module title like "week 4: <UL>TR4 L1STS..." into a label.
function weekLabel(w: any): string {
  const raw = (w.title || '').replace(/^week\s*\d+\s*:?\s*/i, '').trim();
  return raw || `Week ${w.number}`;
}
const heading = week.number === 0 ? 'Setup & Onboarding' : weekLabel(week);

const tutorials = TUTORIALS_BY_WEEK[week.key] || [];

function iconFor(type: string): string {
  switch (type) {
    case 'page': return 'book';
    case 'external': return 'link';
    case 'file': return 'file-text';
    default: return 'file-text';
  }
}
function isEmbed(type: string): boolean {
  return type === 'assignment' || type === 'page';
}
const items = (week.items || []) as any[];
const hasItems = items.some((i) => i.type !== 'subheader');
---

<BaseLayout title={`Week ${week.number}: ${heading} - DESN368`}>
  <nav class="breadcrumb-nav">
    <div class="breadcrumb-container">
      <div class="breadcrumb">
        <a href="/1">Course Overview</a>
        <span class="breadcrumb-separator">&gt;</span>
        <span class="breadcrumb-current">Week {week.number}</span>
      </div>
    </div>
  </nav>

  <main class="course-content two-column">
    <div class="main-content fade-in">
      <Card variant="accent" class="card-enhanced">
        <div class="color-bar color-bar-red"></div>
        <SectionHeader level={1} icon="layers">
          Week {week.number}: {heading}
        </SectionHeader>
        <p class="subtitle">DESN 368 · Spring 2026 · Week {week.number}</p>
      </Card>

      <div class="section-divider"></div>

      <Card variant="enhanced" class="card-enhanced">
        <SectionHeader icon="book" badge={{ text: 'This Week', variant: 'info' }}>
          Assignments &amp; Activities
        </SectionHeader>

        {hasItems ? (
          <div class="resource-list">
            {items.map((item) => (
              item.type === 'subheader' ? (
                <div class="week-subheader">{item.title}</div>
              ) : (
                <a
                  href={item.href}
                  class="resource-item"
                  {...(isEmbed(item.type) ? {} : { target: '_blank', rel: 'noreferrer' })}
                >
                  <div class="resource-icon">
                    <Icon name={iconFor(item.type)} size={20} />
                  </div>
                  <div class="resource-body">
                    <div class="resource-title">{item.title}</div>
                    <div class="resource-desc">
                      {item.type === 'assignment' && 'Assignment'}
                      {item.type === 'page' && 'Page'}
                      {item.type === 'external' && 'External resource'}
                      {item.type === 'file' && 'Download'}
                      {item.type === 'assignment' && item.points ? ` · ${item.points} pts` : ''}
                    </div>
                  </div>
                  <Icon name={isEmbed(item.type) ? 'chevron-down' : 'link'} size={16} class="resource-arrow" />
                </a>
              )
            ))}
          </div>
        ) : (
          <p>Content for this week is being finalized.</p>
        )}
      </Card>

      {tutorials.length > 0 && (
        <>
          <div class="section-divider"></div>
          <Card variant="enhanced" class="card-enhanced">
            <SectionHeader icon="zap" badge={{ text: 'Hands-on', variant: 'success' }}>
              Interactive Tutorials
            </SectionHeader>
            <div class="resource-list">
              {tutorials.map((t) => (
                <a href={t.href} class="resource-item" {...(t.external ? { target: '_blank', rel: 'noreferrer' } : {})}>
                  <div class="resource-icon">
                    <Icon name={t.icon || 'play'} size={20} />
                  </div>
                  <div class="resource-body">
                    <div class="resource-title">{t.title}</div>
                    <div class="resource-desc">{t.desc}</div>
                  </div>
                  <Icon name="link" size={16} class="resource-arrow" />
                </a>
              ))}
            </div>
          </Card>
        </>
      )}
    </div>

    <aside class="sidebar">
      <section class="card card-action card-enhanced">
        <div class="color-bar color-bar-red"></div>
        <h3>
          <span class="icon-enhanced icon-primary">
            <Icon name="zap" size={20} />
          </span>
          Quick Actions
        </h3>
        <div class="quick-action-stack">
          <a href="/1" class="btn btn-secondary">
            <Icon name="book" size={16} class="btn-icon" />
            Course Overview
          </a>
          {prev && (
            <a href={`/1/weeks/${prev.key}`} class="btn btn-secondary">
              <Icon name="chevron-down" size={16} class="btn-icon" />
              Week {prev.number}
            </a>
          )}
          {next && (
            <a href={`/1/weeks/${next.key}`} class="btn btn-start">
              <Icon name="play" size={16} class="btn-icon" />
              Week {next.number}
            </a>
          )}
        </div>
      </section>
    </aside>
  </main>

  <style>
    .subtitle {
      color: var(--text-secondary);
      font-size: 0.9rem;
      margin-top: -8px;
      margin-bottom: 16px;
    }
    .resource-list { display: flex; flex-direction: column; gap: 12px; }
    .week-subheader {
      font-family: var(--font-mono, monospace);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--text-muted);
      padding: 10px 2px 2px;
      border-top: 1px solid var(--border-subtle);
      margin-top: 6px;
    }
    .week-subheader:first-child { border-top: none; margin-top: 0; }
    .resource-item {
      display: flex; align-items: flex-start; gap: 14px; padding: 16px;
      border: 1px solid var(--border-subtle); border-radius: 8px;
      text-decoration: none; color: inherit; background: var(--surface-alt);
      transition: border-color 0.15s, background 0.15s;
    }
    .resource-item:hover { border-color: var(--brand-primary); background: var(--surface); }
    .resource-icon {
      flex-shrink: 0; width: 36px; height: 36px; display: flex;
      align-items: center; justify-content: center;
      background: var(--eagle-red-light); border-radius: 8px; color: var(--eagle-red-text);
    }
    .resource-body { flex: 1; min-width: 0; }
    .resource-title { font-weight: 600; font-size: 0.95rem; color: var(--text-primary); margin-bottom: 4px; }
    .resource-desc { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5; }
    .resource-arrow { flex-shrink: 0; color: var(--text-muted); margin-top: 2px; }
    .quick-action-stack { display: flex; flex-direction: column; gap: 0.5rem; }
  </style>
</BaseLayout>
