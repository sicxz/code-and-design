---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { withCoursePrefix } from '../../lib/courseRegistry';

// Define the weeks data directly for now
const weeks = [
    { number: 1, title: "HTML Elements", subtitle: "Codedex.io — Learn the building blocks of every web page", status: "available" },
    { number: 2, title: "HTML 101 — Document Structure", subtitle: "7-lesson series: skeleton, nesting, attributes, classes, and more", status: "available", link: "/1/html-101/" },
    { number: 3, title: "The Cascade Begins", subtitle: "CSS Separation of Concerns", status: "locked" },
    { number: 4, title: "<UL>TR4 L1STS, 4NCH0R P0W3R, & B0X M4G1C", subtitle: "Lists, Links, and the Box Model", status: "available" },
    { number: 5, title: "Flexbox Mastery", subtitle: "One-dimensional Layouts", status: "locked" },
    { number: 6, title: "Tribute Page", subtitle: "First Complete Project", status: "locked" },
    { number: 7, title: "Grid Systems", subtitle: "Two-dimensional Thinking", status: "locked" },
    { number: 8, title: "Product Landing", subtitle: "Professional Product Page", status: "locked" },
    { number: 9, title: "Portfolio System", subtitle: "Personal Brand Development (2 weeks)", status: "locked" },
    { number: 11, title: "Ship It", subtitle: "Launch & Deploy", status: "locked" }
];
---

<BaseLayout title="Home - DESN368">
    <!-- Breadcrumb Navigation -->
    <nav class="breadcrumb-nav">
        <div class="breadcrumb-container">
            <div class="breadcrumb">
                <span class="breadcrumb-current">Course Overview</span>
            </div>
        </div>
    </nav>

    <main class="course-content two-column">
        <div class="main-content fade-in">
            <!-- Course Introduction -->
            <section class="card card-accent accent-block card-enhanced">
                <div class="color-bar color-bar-red"></div>
                <h2>
                    <span class="icon-enhanced icon-primary">
                        <Icon name="lightbulb" size={20} />
                    </span>
                    Welcome to the <span class="text-gradient">Real Thing</span>
                </h2>
                <p>Most people live on the <strong>surface</strong> of the web—scrolling, clicking, tapping. But beneath all of that, there's <span class="inline-emphasis inline-emphasis-primary">structure</span>. <span class="inline-emphasis inline-emphasis-danger">Logic</span>. <strong>Craft</strong>.</p>

                <p>In this class, you'll learn to read and write the <code>source code</code> that powers the modern internet. Not with drag-and-drop tools. Not through shortcuts. But with the foundational tools—<span class="code-chip code-chip-html">HTML</span> and <span class="code-chip code-chip-css">CSS</span>—the way it actually works.</p>

                <p>You'll start from <strong>nothing</strong>. Build from <strong>scratch</strong>. And by the end, you won't just have a few websites. You'll have a <span class="inline-emphasis inline-emphasis-primary">lens</span>—a way of seeing and shaping digital space that most people never access.</p>

                <div class="hero-statement hero-statement-danger">
                    <p class="hero-statement-copy">
                        This isn't a bootcamp. This isn't a YouTube tutorial. <span class="hero-statement-highlight">This is the real thing.</span>
                    </p>
                </div>
            </section>

            <div class="section-divider with-icon"></div>

            <!-- Student Pledge -->
            <section class="card accent-block-subtle card-enhanced">
                <h2>
                    <span class="icon-enhanced icon-primary">
                        <Icon name="zap" size={20} />
                    </span>
                    Student Pledge
                    <span class="badge badge-primary">Required</span>
                </h2>
                <div class="code-block">
                    $ "I will build my foundation tag by tag.<br>
                    I will understand before I automate.<br>
                    When I use AI, I will remain the architect.<br>
                    I will review every suggestion.<br>
                    I will know what my code does.<br>
                    I will build with intent and intelligence."
                </div>
            </section>

            <div class="section-divider"></div>

            <!-- Course Structure -->
            <section class="card card-enhanced">
                <div class="color-bar color-bar-multi"></div>
                <h2>
                    <span class="icon-enhanced">
                        <Icon name="book" size={20} />
                    </span>
                    Course Structure: 10 Weeks of Foundation
                </h2>
                <div class="week-list">
                    {weeks.map((week) => (
                        <div class="week-item">
                            <div>
                                <h3>
                                    <span class={`status-dot status-${week.status}`}></span>
                                    {week.status === "available" ? (
                                        <a href={week.link || withCoursePrefix('1', `/weeks/week-${week.number}`)}>
                                            Week {week.number}: {week.title}
                                        </a>
                                    ) : (
                                        `Week ${week.number}: ${week.title}`
                                    )}
                                </h3>
                                <p>{week.subtitle}</p>
                            </div>
                            <span class={`state-label state-label-${week.status}`}>
                                {week.status === "available" ? "Available" : "Coming Soon"}
                            </span>
                        </div>
                    ))}
                </div>
            </section>

            <div class="section-divider"></div>

            <!-- Brick by Brick Method -->
            <section class="card accent-block card-enhanced">
                <h2>
                    <span class="icon-enhanced">
                        <Icon name="layers" size={20} />
                    </span>
                    The "Brick by Brick" Method
                </h2>
                
                <h3>Micro-Skills Architecture</h3>
                <p>Each assignment builds one tiny, specific skill that becomes the foundation for the next. You cannot proceed to Assignment B until you demonstrate mastery of Assignment A through multiple assessment gates.</p>
                
                <h3>Four Types of Mastery Gates</h3>
                <ul>
                    <li><strong>Technical Gate</strong> - Code validates and works perfectly</li>
                    <li><strong>Conceptual Gate</strong> - Can explain why it works</li>
                    <li><strong>Debug Gate</strong> - Can fix broken code</li>
                    <li><strong>Teaching Gate</strong> - Can help a classmate understand</li>
                </ul>

                <h3>No Student Left Behind</h3>
                <p>Multiple learning pathways accommodate different learning styles:</p>
                <ul>
                    <li><strong>Visual learners:</strong> Figma integration and visual diagrams</li>
                    <li><strong>Kinesthetic learners:</strong> Hands-on coding from day one</li>
                    <li><strong>Analytical learners:</strong> Deep documentation and technical specs</li>
                    <li><strong>Social learners:</strong> Peer teaching and pair programming</li>
                </ul>

                <h3>Why This Works</h3>
                <p>Traditional courses throw everything at you at once. You memorize, you forget. This course builds muscle memory. Each micro-skill becomes automatic before you move on. By Week 11, you won't have to think about syntax—your fingers will know.</p>
            </section>

            <div class="section-divider"></div>

            <!-- Course Philosophy -->
            <section class="card card-enhanced">
                <div class="color-bar color-bar-multi"></div>
                <h2>
                    <span class="icon-enhanced icon-primary">
                        <Icon name="lightbulb" size={20} />
                    </span>
                    Course Philosophy: "Brick by Brick. Tag by Tag."
                </h2>

                <p>Most people live on the surface of the web—scrolling, clicking, tapping. But beneath all of that, there's structure. Logic. Craft.</p>

                <p>This course teaches students to become <strong>Designer-Coders</strong>—professionals who think visually AND structurally. You'll learn to see the web through two essential lenses:</p>

                <div class="duality-grid-home">
                    <div class="duality-panel duality-panel-primary">
                        <h4>The Designer's Eye:</h4>
                        <p>Typography, color, layout, hierarchy, user experience</p>
                    </div>
                    <div class="duality-panel duality-panel-danger">
                        <h4>The Coder's Mind:</h4>
                        <p>Structure, syntax, logic, problem-solving, optimization</p>
                    </div>
                </div>

                <p>We build understanding brick by brick, tag by tag. Starting with hand-coded foundations, progressively integrating AI as a professional partner. By the end, you won't just make websites—you'll craft digital experiences with both aesthetic sensibility and technical precision.</p>

                <h3>The Journey:</h3>
                <ul>
                    <li><strong>Weeks 1-3:</strong> Foundation (Hand-coding, AI as tutor)</li>
                    <li><strong>Weeks 4-6:</strong> Styling (Design principles, AI as validator)</li>
                    <li><strong>Weeks 7-9:</strong> Layout (Complex systems, AI as co-coder)</li>
                    <li><strong>Weeks 10-11:</strong> Portfolio (Professional work, AI as partner)</li>
                </ul>

                <div class="hero-statement hero-statement-primary">
                    <p class="hero-statement-copy hero-statement-copy-strong">
                        This isn't choosing between design and code. It's mastering both.
                    </p>
                </div>
            </section>

            <div class="section-divider"></div>

            <!-- Core Principles -->
            <section class="card accent-block card-enhanced">
                <h2>
                    <span class="icon-enhanced">
                        <Icon name="layers" size={20} />
                    </span>
                    Core Principles
                </h2>

                <h3>1. Designer-Coder Duality</h3>
                <ul>
                    <li>Every project balances visual design and code structure</li>
                    <li>Learn to switch between aesthetic and technical thinking</li>
                    <li>Understand how design decisions impact code and vice versa</li>
                    <li>Develop fluency in both Figma and code editors</li>
                </ul>

                <h3>2. Build-First Learning</h3>
                <ul>
                    <li>Create something visible every single class</li>
                    <li>Theory follows practice—understand by doing</li>
                    <li>Micro-lessons (5-10 min) integrated with hands-on work</li>
                    <li>No extended lectures or rote memorization</li>
                </ul>

                <h3>3. Three-Spine Integration</h3>
                <ul>
                    <li><strong>Internet Literacy:</strong> Weekly micro-theory on how the web works</li>
                    <li><strong>Immediate Building:</strong> Projects that work from Day 1</li>
                    <li><strong>Design Thinking:</strong> Parallel Figma work reinforcing code concepts</li>
                    <li>All three spines woven throughout every week</li>
                </ul>

                <h3>4. Progressive AI Integration</h3>
                <ul>
                    <li><strong>Week 1:</strong> Setup and orientation, no AI yet</li>
                    <li><strong>Weeks 2-3:</strong> AI as reference ("What is a &lt;div&gt;?", "Explain CSS specificity")</li>
                    <li><strong>Weeks 4-5:</strong> AI as validator ("Is my HTML semantic?", "Check my form structure")</li>
                    <li><strong>Weeks 6-7:</strong> AI as suggester ("How would you style this?", "Show me flexbox options")</li>
                    <li><strong>Weeks 8-9:</strong> AI as co-coder (Copilot autocomplete, generating components)</li>
                    <li><strong>Weeks 10-11:</strong> AI as partner (Full professional workflow, prompt engineering)</li>
                </ul>

                <h3>5. AI as Partner, Not Replacement</h3>
                <ul>
                    <li>Students must understand what AI generates</li>
                    <li>Ability to review, debug, and improve AI suggestions</li>
                    <li>Learn when to accept, modify, or reject AI code</li>
                    <li>Develop prompt engineering skills specific to web development</li>
                </ul>
            </section>
        </div>

        <aside class="sidebar">
            <!-- Quick Actions -->
            <section class="card card-action card-enhanced">
                <div class="color-bar color-bar-red"></div>
                <h3>
                    <span class="icon-enhanced icon-primary">
                        <Icon name="zap" size={20} />
                    </span>
                    Quick Actions
                    <span class="badge badge-warning">New</span>
                </h3>
                <div class="quick-action-stack">
                    <a href="/1/syllabus" class="btn btn-secondary">
                        <Icon name="book" size={16} class="btn-icon" />
                        View Syllabus
                    </a>
                    <a href="/1-fall-2025" class="btn btn-secondary">
                        <Icon name="calendar" size={16} class="btn-icon" />
                        Fall 2025 Archive
                    </a>
                    <a href="/1/style-guide" class="btn btn-secondary">
                        <Icon name="layers" size={16} class="btn-icon" />
                        View Style Guide
                    </a>
                    <a href="/1/weeks/week-4" class="btn btn-start">
                        <Icon name="play" size={16} class="btn-icon" />
                        Start Week 4
                    </a>
                    
                    <a href="https://github.com/sicxz/desn368-f25" class="btn btn-secondary" target="_blank">
                        <Icon name="github" size={16} class="btn-icon" />
                        GitHub Repo
                    </a>
                </div>
            </section>

            <!-- Course Tools -->
            <section class="card">
                <h3>
                    <Icon name="settings" size={20} class="section-icon" />
                    Essential Tools
                </h3>

                <!-- VS Code Block -->
                <div class="tool-block">
                    <h4>VS Code</h4>
                    <p>Your code editor for the semester</p>
                    <a href="#" class="btn btn-primary">Download VS Code</a>
                </div>

                <!-- CodePen Block -->
                <div class="tool-block">
                    <h4>CodePen</h4>
                    <p>Online playground for quick experiments</p>
                    <a href="https://codepen.io/" class="btn btn-outline" target="_blank">Create Account</a>
                </div>

                <!-- Firefox DevTools Block -->
                <div class="tool-block-mozilla">
                    <a href="https://firefox-source-docs.mozilla.org/devtools-user/" class="tool-block-mozilla-header" target="_blank">Learn Firefox DevTools</a>
                    <div class="tool-block-mozilla-body">
                        <p><a href="https://firefox-source-docs.mozilla.org/devtools-user/" class="devtools-link" target="_blank">Firefox Developer Tools</a> is a comprehensive set of web developer tools built directly into Firefox. Inspect, debug, and optimize your HTML, CSS, and JavaScript.</p>

                        <div class="mozilla-note">
                            <div class="mozilla-note-content">
                                <svg class="mozilla-note-icon" viewBox="0 0 24 24">
                                    <circle cx="12" cy="12" r="10"/>
                                    <line x1="12" y1="16" x2="12" y2="12"/>
                                    <line x1="12" y1="8" x2="12.01" y2="8"/>
                                </svg>
                                <div class="mozilla-note-body">
                                    <strong>Note</strong>
                                    <p>If you are just getting started with web development and browser developer tools, check out our <a href="https://developer.mozilla.org/en-US/docs/Learn/Common_questions/Tools_and_setup/What_are_browser_developer_tools" target="_blank">What are browser developer tools?</a> guide for good starting points.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Philosophy Quote -->
            <section class="card card-accent philosophy-quote-card">
                <div class="philosophy-quote-mark">
                    <Icon name="quote" size={48} class="quote-icon" />
                </div>
                <blockquote class="philosophy-quote-copy">
                    <span class="quote-glyph">"</span>We're not making pretty pages. We're building <span class="inline-emphasis inline-emphasis-primary inline-emphasis-strong">digital infrastructure</span>.<span class="quote-glyph">"</span>
                </blockquote>
                <div class="philosophy-quote-attribution">— Course Philosophy</div>
            </section>

            <!-- Quick Reference -->
            <section class="card">
                <h3>
                    <Icon name="book" size={20} class="section-icon" />
                    Quick Reference
                </h3>

                <!-- HTML Tags -->
                <div class="reference-section">
                    <button class="reference-toggle" onclick="toggleReference('html')">
                        <span>HTML Tags</span>
                        <Icon name="chevron-down" size={16} class="chevron" />
                    </button>
                    <div class="reference-content" id="html-content">
                        <div class="reference-item">
                            <span class="tag">&lt;h1&gt;</span>
                            <span class="desc">Main heading</span>
                        </div>
                        <div class="reference-item">
                            <span class="tag">&lt;p&gt;</span>
                            <span class="desc">Paragraph</span>
                        </div>
                        <div class="reference-item">
                            <span class="tag">&lt;a&gt;</span>
                            <span class="desc">Link</span>
                        </div>
                        <div class="reference-item">
                            <span class="tag">&lt;img&gt;</span>
                            <span class="desc">Image</span>
                        </div>
                        <div class="reference-item">
                            <span class="tag">&lt;div&gt;</span>
                            <span class="desc">Container</span>
                        </div>
                    </div>
                </div>

                <!-- CSS Properties -->
                <div class="reference-section">
                    <button class="reference-toggle" onclick="toggleReference('css')">
                        <span>CSS Properties</span>
                        <Icon name="chevron-down" size={16} class="chevron" />
                    </button>
                    <div class="reference-content" id="css-content">
                        <div class="reference-item">
                            <span class="tag">color</span>
                            <span class="desc">Text color</span>
                        </div>
                        <div class="reference-item">
                            <span class="tag">background</span>
                            <span class="desc">Background color</span>
                        </div>
                        <div class="reference-item">
                            <span class="tag">font-size</span>
                            <span class="desc">Text size</span>
                        </div>
                        <div class="reference-item">
                            <span class="tag">margin</span>
                            <span class="desc">Outside spacing</span>
                        </div>
                        <div class="reference-item">
                            <span class="tag">padding</span>
                            <span class="desc">Inside spacing</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Resources -->
            <section class="card card-resource">
                <h3>External Resources</h3>
                <ul class="resource-list-clean">
                    <li>
                        <a href="https://developer.mozilla.org/en-US/" target="_blank">MDN Web Docs</a>
                    </li>
                    <li>
                        <a href="https://validator.w3.org/" target="_blank">W3C Validator</a>
                    </li>
                    <li>
                        <a href="https://css-tricks.com/" target="_blank">CSS-Tricks</a>
                    </li>
                    <li>
                        <a href="https://codepen.io/" target="_blank">CodePen</a>
                    </li>
                </ul>
            </section>
        </aside>
    </main>

    <style>
        .inline-emphasis {
            font-weight: 600;
        }

        .inline-emphasis-primary {
            color: var(--brand-primary);
        }

        .inline-emphasis-danger {
            color: var(--brand-red);
        }

        .inline-emphasis-strong {
            font-weight: 700;
        }

        .code-chip {
            display: inline-flex;
            align-items: center;
            padding: 2px 8px;
            border-radius: 999px;
            font-family: var(--font-mono);
            font-size: 0.92rem;
            border: 1px solid transparent;
        }

        .code-chip-html {
            background: var(--eagle-red-light);
            color: var(--eagle-red-text);
            border-color: rgba(183, 20, 46, 0.22);
        }

        .code-chip-css {
            background: var(--eagle-blue-light);
            color: var(--eagle-blue-text);
            border-color: rgba(1, 186, 239, 0.22);
        }

        .hero-statement {
            margin: 20px 0;
            padding: 20px 22px;
            border-radius: 8px;
            background: var(--gradient-accent);
        }

        .hero-statement-danger {
            border-left: 4px solid var(--brand-red);
        }

        .hero-statement-primary {
            border-left: 4px solid var(--brand-primary);
        }

        .hero-statement-copy {
            margin: 0;
            font-size: 1.05rem;
            font-style: italic;
            font-weight: 500;
            line-height: 1.65;
        }

        .hero-statement-copy-strong {
            color: var(--brand-primary);
            font-weight: 600;
        }

        .hero-statement-highlight {
            color: var(--brand-red);
            font-weight: 700;
        }

        .duality-grid-home {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 20px;
            margin: 20px 0;
        }

        .duality-panel {
            padding: 16px;
            border-radius: 8px;
            background: var(--gradient-accent);
        }

        .duality-panel h4 {
            margin: 0 0 8px 0;
            font-size: 1rem;
        }

        .duality-panel p {
            margin: 0;
            font-size: 14px;
        }

        .duality-panel-primary {
            border-left: 4px solid var(--brand-primary);
        }

        .duality-panel-primary h4 {
            color: var(--brand-primary);
        }

        .duality-panel-danger {
            border-left: 4px solid var(--brand-red);
        }

        .duality-panel-danger h4 {
            color: var(--brand-red);
        }

        .quick-action-stack {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .philosophy-quote-card {
            position: relative;
        }

        .philosophy-quote-mark {
            position: absolute;
            top: 16px;
            right: 16px;
            opacity: 0.1;
            transform: rotate(12deg);
        }

        .philosophy-quote-copy {
            position: relative;
            z-index: 1;
            margin: 0;
            font-style: italic;
            font-weight: 500;
            line-height: 1.6;
        }

        .quote-glyph {
            font-size: 20px;
        }

        .philosophy-quote-attribution {
            margin-top: 12px;
            font-size: 12px;
            color: var(--text-muted);
        }

        .resource-list-clean {
            list-style: none;
            padding: 0;
            font-size: 13px;
        }

        .resource-list-clean li + li {
            margin-top: 8px;
        }

        @media (max-width: 640px) {
            .duality-grid-home {
                grid-template-columns: 1fr;
            }
        }
    </style>
</BaseLayout>
