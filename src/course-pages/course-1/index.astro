---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import manifest from './courseManifest.json';
import { TUTORIAL_LIBRARY } from './tutorialsByWeek';

const weeks = manifest.weeks as any[];
const infoItems = (manifest.info_items as any[]) || [];
const resources = (manifest.resources as any[]) || [];

function weekLabel(w: any): string {
  if (w.number === 0) return 'Setup & Onboarding';
  const raw = (w.title || '').replace(/^week\s*\d+\s*:?\s*/i, '').trim();
  return raw || `Week ${w.number}`;
}
function assignmentCount(w: any): number {
  return (w.items || []).filter((i: any) => i.type === 'assignment' || i.type === 'page').length;
}

// Projects pulled from the assignment set (by slug prefix in href).
const projectHrefs = weeks
  .flatMap((w) => w.items)
  .filter((i: any) => i.type === 'assignment' && /\/(p-?\d|p\d|project-\d)/i.test(i.href || ''));
---

<BaseLayout title="Home - DESN368">
    <nav class="breadcrumb-nav">
        <div class="breadcrumb-container">
            <div class="breadcrumb">
                <span class="breadcrumb-current">Course Overview</span>
            </div>
        </div>
    </nav>

    <main class="course-content two-column">
        <div class="main-content fade-in">
            <!-- Welcome -->
            <section class="card card-accent accent-block card-enhanced">
                <div class="color-bar color-bar-red"></div>
                <h2>
                    <span class="icon-enhanced icon-primary"><Icon name="lightbulb" size={20} /></span>
                    Welcome to the <span class="text-gradient">Real Thing</span>
                </h2>
                <p>Most people live on the <strong>surface</strong> of the web—scrolling, clicking, tapping. But beneath all of that, there's <span class="inline-emphasis inline-emphasis-primary">structure</span>. <span class="inline-emphasis inline-emphasis-danger">Logic</span>. <strong>Craft</strong>.</p>
                <p>In this class, you'll learn to read and write the <code>source code</code> that powers the modern internet—with <span class="code-chip code-chip-html">HTML</span> and <span class="code-chip code-chip-css">CSS</span>, the way it actually works.</p>
                <p><strong>Everything you need lives right here</strong>—every week, every assignment, every tutorial. No need to dig through Canvas.</p>
            </section>

            <div class="section-divider"></div>

            <!-- Complete Week Directory -->
            <section class="card card-enhanced">
                <div class="color-bar color-bar-multi"></div>
                <h2>
                    <span class="icon-enhanced"><Icon name="book" size={20} /></span>
                    Course Weeks
                    <span class="badge badge-primary">{weeks.length} weeks</span>
                </h2>
                <p class="dir-note">Every week's assignments, activities, and tutorials—hosted on this site.</p>
                <div class="week-grid">
                    {weeks.map((week) => (
                        <a class="week-card" href={`/1/weeks/${week.key}`}>
                            <div class="week-card-num">{week.number === 0 ? 'Setup' : `Week ${week.number}`}</div>
                            <div class="week-card-title">{weekLabel(week)}</div>
                            <div class="week-card-meta">{assignmentCount(week)} items <Icon name="link" size={13} /></div>
                        </a>
                    ))}
                </div>
            </section>

            <div class="section-divider"></div>

            <!-- Interactive Tutorial Library -->
            <section class="card card-enhanced">
                <h2>
                    <span class="icon-enhanced icon-primary"><Icon name="zap" size={20} /></span>
                    Interactive Tutorial Library
                    <span class="badge badge-warning">Hands-on</span>
                </h2>
                <p class="dir-note">Standalone, hands-on tutorials—open any of them and start building.</p>
                <div class="tut-grid">
                    {TUTORIAL_LIBRARY.map((t) => (
                        <a class="tut-card" href={t.href} {...(t.external ? { target: '_blank', rel: 'noreferrer' } : {})}>
                            <span class="tut-icon"><Icon name={t.icon || 'play'} size={18} /></span>
                            <span class="tut-body">
                                <span class="tut-title">{t.title}</span>
                                <span class="tut-desc">{t.desc}</span>
                            </span>
                        </a>
                    ))}
                </div>
            </section>

            <div class="section-divider"></div>

            <!-- Student Pledge -->
            <section class="card accent-block-subtle card-enhanced">
                <h2>
                    <span class="icon-enhanced icon-primary"><Icon name="zap" size={20} /></span>
                    Student Pledge
                    <span class="badge badge-primary">Required</span>
                </h2>
                <div class="code-block">
                    $ "I will build my foundation tag by tag.<br>
                    I will understand before I automate.<br>
                    When I use AI, I will remain the architect.<br>
                    I will review every suggestion.<br>
                    I will know what my code does.<br>
                    I will build with intent and intelligence."
                </div>
            </section>
        </div>

        <aside class="sidebar">
            <!-- Quick Actions -->
            <section class="card card-action card-enhanced">
                <div class="color-bar color-bar-red"></div>
                <h3>
                    <span class="icon-enhanced icon-primary"><Icon name="zap" size={20} /></span>
                    Quick Actions
                </h3>
                <div class="quick-action-stack">
                    <a href="/1/syllabus" class="btn btn-secondary"><Icon name="book" size={16} class="btn-icon" />View Syllabus</a>
                    <a href="/1/style-guide" class="btn btn-secondary"><Icon name="layers" size={16} class="btn-icon" />Style Guide</a>
                    <a href={`/1/weeks/${weeks[weeks.length - 1].key}`} class="btn btn-start"><Icon name="play" size={16} class="btn-icon" />Latest Week</a>
                    <a href="https://github.com/sicxz/desn368-f25" class="btn btn-secondary" target="_blank"><Icon name="github" size={16} class="btn-icon" />GitHub Repo</a>
                </div>
            </section>

            <!-- Start Here / Important Info -->
            {infoItems.length > 0 && (
                <section class="card">
                    <h3><Icon name="lightbulb" size={20} class="section-icon" />Start Here</h3>
                    <ul class="info-list">
                        {infoItems.map((i) => (
                            i.type === 'subheader'
                                ? <li class="info-sub">{i.title}</li>
                                : <li><a href={i.href} {...(i.type === 'external' ? { target: '_blank', rel: 'noreferrer' } : {})}>{i.title}</a></li>
                        ))}
                    </ul>
                </section>
            )}

            <!-- Essential Tools -->
            <section class="card">
                <h3><Icon name="settings" size={20} class="section-icon" />Essential Tools</h3>
                <div class="tool-block">
                    <h4>VS Code</h4>
                    <p>Your code editor for the semester</p>
                    <a href="https://code.visualstudio.com/" class="btn btn-primary" target="_blank">Download VS Code</a>
                </div>
                <div class="tool-block">
                    <h4>CodePen</h4>
                    <p>Online playground for quick experiments</p>
                    <a href="https://codepen.io/" class="btn btn-outline" target="_blank">Create Account</a>
                </div>
                <div class="tool-block">
                    <h4>Firefox DevTools</h4>
                    <p>Inspect, debug, and optimize your HTML &amp; CSS. Start with our on-site field guide.</p>
                    <a href="/resources/dev-tools-fieldguide/" class="btn btn-primary" target="_blank">Open the Field Guide</a>
                </div>
            </section>

            <!-- Resources -->
            {resources.length > 0 && (
                <section class="card card-resource">
                    <h3>Resources &amp; Templates</h3>
                    <ul class="resource-list-clean">
                        {resources.map((r) => (
                            <li><a href={r.href}>{r.title}</a></li>
                        ))}
                    </ul>
                </section>
            )}

            <!-- External Reference -->
            <section class="card card-resource">
                <h3>Reference</h3>
                <ul class="resource-list-clean">
                    <li><a href="https://developer.mozilla.org/en-US/" target="_blank">MDN Web Docs</a></li>
                    <li><a href="https://validator.w3.org/" target="_blank">W3C Validator</a></li>
                    <li><a href="https://css-tricks.com/" target="_blank">CSS-Tricks</a></li>
                </ul>
            </section>
        </aside>
    </main>

    <style>
        .inline-emphasis { font-weight: 600; }
        .inline-emphasis-primary { color: var(--brand-primary); }
        .inline-emphasis-danger { color: var(--brand-red); }
        .code-chip { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 999px; font-family: var(--font-mono); font-size: 0.92rem; border: 1px solid transparent; }
        .code-chip-html { background: var(--eagle-red-light); color: var(--eagle-red-text); border-color: rgba(183, 20, 46, 0.22); }
        .code-chip-css { background: var(--eagle-blue-light); color: var(--eagle-blue-text); border-color: rgba(1, 186, 239, 0.22); }

        .dir-note { color: var(--text-secondary); font-size: 0.9rem; margin: -4px 0 16px; }

        .week-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; }
        .week-card {
            display: flex; flex-direction: column; gap: 6px; padding: 16px;
            border: 1px solid var(--border-subtle); border-radius: 10px;
            background: var(--surface-alt); text-decoration: none; color: inherit;
            transition: border-color 0.15s, background 0.15s, transform 0.15s;
        }
        .week-card:hover { border-color: var(--brand-primary); background: var(--surface); transform: translateY(-2px); }
        .week-card-num { font-family: var(--font-mono, monospace); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--eagle-red-text); }
        .week-card-title { font-weight: 600; font-size: 0.98rem; color: var(--text-primary); line-height: 1.25; }
        .week-card-meta { display: flex; align-items: center; gap: 5px; font-size: 0.78rem; color: var(--text-muted); margin-top: auto; }

        .tut-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; }
        .tut-card { display: flex; gap: 12px; padding: 14px; border: 1px solid var(--border-subtle); border-radius: 10px; background: var(--surface-alt); text-decoration: none; color: inherit; transition: border-color 0.15s, background 0.15s; }
        .tut-card:hover { border-color: var(--brand-primary); background: var(--surface); }
        .tut-icon { flex-shrink: 0; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; background: var(--eagle-red-light); border-radius: 8px; color: var(--eagle-red-text); }
        .tut-body { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
        .tut-title { font-weight: 600; font-size: 0.92rem; color: var(--text-primary); }
        .tut-desc { font-size: 0.82rem; color: var(--text-secondary); line-height: 1.45; }

        .info-list { list-style: none; padding: 0; margin: 0; font-size: 0.86rem; }
        .info-list li { margin-bottom: 7px; }
        .info-list li.info-sub { font-weight: 700; text-transform: uppercase; font-size: 0.72rem; letter-spacing: 0.04em; color: var(--text-muted); margin-top: 10px; }
        .info-list a { color: var(--brand-primary); text-decoration: none; }
        .info-list a:hover { text-decoration: underline; }

        .resource-list-clean { list-style: none; padding: 0; font-size: 13px; }
        .resource-list-clean li + li { margin-top: 8px; }
        .quick-action-stack { display: flex; flex-direction: column; gap: 0.5rem; }
    </style>
</BaseLayout>
