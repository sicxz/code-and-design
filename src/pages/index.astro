---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import courseData from '../data/course-data.json';

type WeekRecord = {
  week: number;
  route: string;
  title: string;
  unit: string | null;
  interaction_question: string | null;
  canvas_items: Array<{ content_type: string }>;
  curriculum_files: Record<string, Array<{ title: string; path: string }>>;
};

const weeks = (courseData.weeks as WeekRecord[]).sort((a, b) => a.week - b.week);

const projectCards = [
  {
    title: 'Project 1: Signal + State',
    weeks: 'Weeks 1-3',
    note: 'Theme system, persistence, user preferences, accessibility.',
  },
  {
    title: 'Project 2: Lost in the Scroll',
    weeks: 'Weeks 5-9',
    note: 'Scrollytelling narrative from blueprint to final deployed experience.',
  },
];

type ResourceLink = { label: string; href: string; external?: boolean };
type ResourceGroup = { title: string; links: ResourceLink[] };

const resourceGroups: ResourceGroup[] = [
  {
    title: 'Quick Actions',
    links: [
      { label: 'View Syllabus', href: '/syllabus' },
      { label: 'Week 0: The On-Ramp', href: '/weeks/week-0' },
      {
        label: 'GitHub Template',
        href: 'https://github.com/sicxz/DESN-378-code-design-2',
        external: true,
      },
    ],
  },
  {
    title: 'Essential Tools',
    links: [
      {
        label: 'Firefox Developer Edition',
        href: 'https://www.mozilla.org/en-US/firefox/developer/',
        external: true,
      },
      { label: 'Chrome', href: 'https://www.google.com/chrome/', external: true },
      {
        label: 'VS Code Insiders',
        href: 'https://code.visualstudio.com/insiders/',
        external: true,
      },
      { label: 'CodePen', href: 'https://codepen.io/', external: true },
    ],
  },
  {
    title: 'Reference',
    links: [
      {
        label: 'Chrome DevTools Overview',
        href: 'https://developer.chrome.com/docs/devtools/',
        external: true,
      },
      {
        label: 'Chrome Console Reference',
        href: 'https://developer.chrome.com/docs/devtools/console/',
        external: true,
      },
      {
        label: 'Firefox DevTools Docs',
        href: 'https://firefox-source-docs.mozilla.org/devtools-user/',
        external: true,
      },
      {
        label: 'JavaScript First Steps (MDN)',
        href: 'https://developer.mozilla.org/en-US/docs/Learn/JavaScript/First_steps',
        external: true,
      },
      { label: 'JavaScript.info', href: 'https://javascript.info/', external: true },
    ],
  },
  {
    title: 'Watch',
    links: [
      {
        label: 'JavaScript in 100 Seconds (Fireship)',
        href: 'https://www.youtube.com/watch?v=DHjqpvDnNGE',
        external: true,
      },
      {
        label: 'DevTools Crash Course (Traversy Media)',
        href: 'https://www.youtube.com/watch?v=Gz_6Nw82ga4',
        external: true,
      },
    ],
  },
  {
    title: 'Hidden Gems',
    links: [
      {
        label: 'JavaScript for Designers (Rachel Andrew)',
        href: 'https://alistapart.com/article/javascript-for-designers/',
        external: true,
      },
      {
        label: 'Demystifying JavaScript (Smashing Magazine)',
        href: 'https://www.smashingmagazine.com/2019/10/javascript-designers/',
        external: true,
      },
      {
        label: 'The Weird History of JavaScript (Fireship)',
        href: 'https://www.youtube.com/watch?v=Sh6lK57Cuk4',
        external: true,
      },
      {
        label: 'Understanding the Weird Parts (Tony Alicea)',
        href: 'https://www.udemy.com/course/understand-javascript/',
        external: true,
      },
    ],
  },
];
---

<BaseLayout title="DESN378: Code + Design 2">
  <!-- Tab Nav Bar -->
  <nav class="dashboard-nav" style="position:sticky;top:0;z-index:200;">
    <div class="dashboard-nav-inner">
      <a href="/" class="tab-link active" aria-current="page">
        <Icon name="book" size={15} />
        Overview
      </a>

      <button class="tab-link" id="weeks-toggle" type="button" aria-expanded="false" aria-controls="weeks-panel">
        <Icon name="calendar" size={15} />
        Weeks
        <svg class="tab-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>

      <a href="/syllabus" class="tab-link">
        <Icon name="clipboard-list" size={15} />
        Syllabus
      </a>

      <a href="/assignments" class="tab-link">
        <Icon name="layers" size={15} />
        Assignments
      </a>
    </div>
  </nav>

  <div class="dropdown-panel" id="weeks-panel" role="menu" aria-label="Weeks" style="display:none;position:fixed;z-index:9999;">
    {weeks.map((w) => (
      <a href={w.route} class="dropdown-item" role="menuitem">
        <span class="dropdown-week-num">W{w.week}</span>
        <span>{w.title.replace(`Week ${w.week}: `, '')}</span>
      </a>
    ))}
  </div>

  <!-- Main Content -->
  <main class="dashboard-content" style="position:relative;z-index:1;">
    <!-- Course overview -->
    <section class="content-section">
      <div class="overview-card">
        <h2 class="overview-heading">Welcome to the Next Layer</h2>
        <p class="overview-lead">
          You know how to design and build sites with HTML (structure) and CSS (style).
          <em>Pages that look right.</em>
          <em>Layouts that hold together.</em>
        </p>
        <p class="overview-body">
          But they don&rsquo;t <em>do</em> anything yet. What&rsquo;s missing is <strong>behavior</strong>.
        </p>
        <p class="overview-body">
          This quarter, you add the nervous system&mdash;the layer that senses a click, responds to a scroll,
          remembers a preference. The layer that makes the difference between a static page and an
          <em>experience</em>.
        </p>
        <p class="overview-body">
          You will learn JavaScript the way designers need it.
        </p>
        <p class="overview-highlight">
          <strong>Behavior first.</strong> <strong>Syntax second.</strong>
          <br />
          <span class="overview-highlight-sub">&ldquo;How should this feel?&rdquo; before &ldquo;How do I code this?&rdquo;</span>
        </p>
        <p class="overview-body overview-closing">
          This is not computer science. It&rsquo;s Interaction Design, where code is the material we use to shape
          experience.
        </p>
      </div>
    </section>

    <!-- Week Grid -->
    <section class="content-section">
      <h2 class="section-title">Weekly Curriculum</h2>
      <div class="week-grid">
        {weeks.map((week) => {
          const totalFiles = Object.values(week.curriculum_files).reduce((sum, entries) => sum + entries.length, 0);
          return (
            <a href={week.route} class="week-card">
              <div class="week-card-header">
                <span class="week-badge">W{week.week}</span>
                <span class="week-card-title">{week.title.replace(`Week ${week.week}: `, '')}</span>
              </div>
              {week.interaction_question && (
                <p class="week-card-question">{week.interaction_question}</p>
              )}
              <div class="week-card-meta">
                {week.unit && <span class="week-unit">{week.unit}</span>}
                <span>{totalFiles} files</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Projects -->
    <section class="content-section">
      <h2 class="section-title">Course Projects</h2>
      <div class="project-grid">
        {projectCards.map((project) => (
          <div class="project-card">
            <div class="project-card-header">
              <h3>{project.title}</h3>
              <span class="project-weeks">{project.weeks}</span>
            </div>
            <p>{project.note}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Resources -->
    <section class="content-section">
      <h2 class="section-title">Resources</h2>
      <div class="resources-grid">
        {resourceGroups.map((group) => (
          <div class="resource-group">
            <h4>{group.title}</h4>
            <ul class="resource-list">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Philosophy + Protocol (collapsed) -->
    <section class="content-section">
      <details class="philosophy-toggle">
        <summary class="section-title summary-title">
          <span>Course Philosophy &amp; Protocol</span>
          <svg class="toggle-chevron" width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1.5 1.5l4.5 5 4.5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </summary>
        <div class="philosophy-content">
          <div class="philosophy-grid">
            <div class="philosophy-block">
              <h3>Sense. Respond. Adapt.</h3>
              <p>
                You already know structure. You already know style. This course adds the third layer:
                <strong>behavior</strong>. Code is treated as a creative material.
              </p>
              <p>
                The question is not just "what syntax do I use?" It's
                <strong>"how should this feel?"</strong>
              </p>
              <div class="lens-row">
                <div class="lens-card">
                  <h4>The Interaction Designer</h4>
                  <p>Timing, feedback, state, motion, user respect.</p>
                </div>
                <div class="lens-card">
                  <h4>The Behavioral Coder</h4>
                  <p>Events, DOM, animation systems, preference APIs.</p>
                </div>
              </div>
            </div>
            <div class="philosophy-block">
              <h3>The Protocol</h3>
              <div class="protocol-block">
                <p>"I will design behavior, not just apply effects.</p>
                <p>I will ask 'how should this feel?' before 'how do I code this?'</p>
                <p>When I use AI, I will understand what it generates.</p>
                <p>I will respect user preferences and build for everyone.</p>
                <p>I will develop my creative voice through code.</p>
                <p>I will make things that respond with intent."</p>
              </div>
            </div>
          </div>
        </div>
      </details>
    </section>
  </main>

  <script>
    function initDashboard() {
      const toggle = document.getElementById('weeks-toggle');
      const panel = document.getElementById('weeks-panel');
      if (!toggle || !panel) return;

      function openPanel() {
        const rect = toggle!.getBoundingClientRect();
        panel!.style.display = 'block';
        panel!.style.top = rect.bottom + 'px';
        panel!.style.left = rect.left + 'px';
        toggle!.setAttribute('aria-expanded', 'true');
        toggle!.classList.add('dropdown-open');
      }

      function closePanel() {
        panel!.style.display = 'none';
        toggle!.setAttribute('aria-expanded', 'false');
        toggle!.classList.remove('dropdown-open');
      }

      function isOpen() {
        return panel!.style.display !== 'none';
      }

      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        if (isOpen()) { closePanel(); } else { openPanel(); }
      });

      document.addEventListener('click', (e) => {
        if (isOpen() && !panel!.contains(e.target as Node)) {
          closePanel();
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen()) {
          closePanel();
          toggle!.focus();
        }
      });
    }

    document.addEventListener('astro:page-load', initDashboard);
    if (document.readyState !== 'loading') {
      initDashboard();
    } else {
      document.addEventListener('DOMContentLoaded', initDashboard);
    }
  </script>

  <style>
    /* ── Tab Nav Bar ───────────────────────────────────── */
    .dashboard-nav {
      background: var(--bg-card);
      border-bottom: 1px solid var(--border-color);
    }

    .dashboard-nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1rem;
      display: flex;
      align-items: stretch;
      gap: 0;
    }

    .tab-link {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.65rem 1rem;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--text-secondary);
      text-decoration: none;
      border: none;
      border-bottom: 2px solid transparent;
      background: none;
      white-space: nowrap;
      transition: color 0.1s ease, border-color 0.1s ease;
      cursor: pointer;
      font-family: inherit;
    }

    .tab-link:hover {
      color: var(--text-primary);
    }

    .tab-link.active {
      color: var(--text-primary);
      border-bottom-color: var(--brand-primary, var(--neural-teal));
      font-weight: 600;
    }

    /* ── Weeks Dropdown ────────────────────────────────── */
    .tab-chevron {
      transition: transform 0.15s ease;
      opacity: 0.6;
    }

    :global(.dropdown-open) .tab-chevron {
      transform: rotate(180deg);
    }

    :global(.dropdown-open) {
      color: var(--text-primary);
      border-bottom-color: var(--brand-primary, var(--neural-teal));
    }

    :global(.dropdown-panel) {
      min-width: 260px;
      max-height: 70vh;
      overflow-y: auto;
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 0 0 10px 10px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
      padding: 0.35rem 0;
    }

    :global(.dropdown-item) {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.45rem 0.85rem;
      font-size: 0.82rem;
      color: var(--text-secondary);
      text-decoration: none;
      transition: background 0.1s ease;
    }

    :global(.dropdown-item:hover) {
      background: var(--bg-tertiary);
      color: var(--text-primary);
    }

    :global(.dropdown-week-num) {
      font-family: var(--font-mono, 'SF Mono', 'Fira Code', monospace);
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--text-muted);
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 4px;
      padding: 0.1rem 0.35rem;
      min-width: 2rem;
      text-align: center;
    }

    :global(.dropdown-item:hover .dropdown-week-num) {
      color: var(--text-primary);
      border-color: var(--brand-primary, var(--neural-teal));
    }

    /* ── Main Content ──────────────────────────────────── */
    .dashboard-content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1.25rem 1rem 3rem;
    }

    .content-section {
      margin-bottom: 1.75rem;
    }

    /* ── Course overview ───────────────────────────────── */
    .overview-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      padding: 1.15rem 1.25rem 1.25rem;
    }

    .overview-heading {
      margin: 0 0 0.75rem;
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-primary);
      letter-spacing: -0.02em;
    }

    .overview-lead {
      margin: 0 0 0.65rem;
      font-size: 1rem;
      line-height: 1.55;
      color: var(--text-secondary);
    }

    .overview-lead em {
      display: block;
      font-style: italic;
      color: var(--text-muted);
      margin-top: 0.2rem;
    }

    .overview-body {
      margin: 0 0 0.65rem;
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--text-secondary);
    }

    .overview-body:last-of-type {
      margin-bottom: 0;
    }

    .overview-highlight {
      margin: 0.85rem 0 1rem;
      padding: 0.75rem 1rem;
      border-left: 4px solid var(--brand-primary, var(--neural-teal));
      background: rgba(1, 183, 153, 0.08);
      border-radius: 0 8px 8px 0;
      font-size: 0.98rem;
      line-height: 1.5;
      color: var(--text-primary);
    }

    .overview-highlight-sub {
      display: inline-block;
      margin-top: 0.35rem;
      font-size: 0.88rem;
      font-weight: 500;
      color: var(--text-secondary);
    }

    .overview-closing {
      margin-bottom: 0 !important;
    }

    /* ── Resources ─────────────────────────────────────── */
    .resources-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 0.75rem;
    }

    .resource-group {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 0.75rem 0.85rem;
    }

    .resource-group h4 {
      margin: 0 0 0.5rem;
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text-muted);
    }

    .resource-list {
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .resource-list li {
      margin: 0;
      padding: 0;
    }

    .resource-list li + li {
      margin-top: 0.35rem;
    }

    .resource-list a {
      font-size: 0.85rem;
      color: var(--text-link, var(--cyan));
      text-decoration: none;
      line-height: 1.4;
    }

    .resource-list a:hover {
      text-decoration: underline;
    }

    .section-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 0 0 0.75rem;
      padding-bottom: 0.45rem;
      border-bottom: 1px solid var(--border-color);
    }

    /* ── Week Grid ─────────────────────────────────────── */
    .week-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 0.65rem;
    }

    .week-card {
      display: flex;
      flex-direction: column;
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 0.75rem 0.9rem;
      text-decoration: none;
      transition: border-color 0.15s ease, background 0.15s ease;
    }

    .week-card:hover {
      border-color: var(--brand-primary, var(--neural-teal));
      background: var(--bg-tertiary);
    }

    .week-card-header {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.3rem;
    }

    .week-badge {
      font-family: var(--font-mono, 'SF Mono', 'Fira Code', monospace);
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--brand-primary, var(--neural-teal));
      background: rgba(1, 183, 153, 0.12);
      border: 1px solid rgba(1, 183, 153, 0.25);
      border-radius: 4px;
      padding: 0.1rem 0.35rem;
      flex-shrink: 0;
    }

    .week-card-title {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1.3;
    }

    .week-card-question {
      margin: 0;
      font-size: 0.8rem;
      color: var(--text-secondary);
      line-height: 1.4;
      flex: 1;
    }

    .week-card-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 0.45rem;
      font-size: 0.72rem;
      color: var(--text-muted);
    }

    .week-unit {
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 999px;
      padding: 0.05rem 0.45rem;
      font-size: 0.68rem;
    }

    /* ── Project Grid ──────────────────────────────────── */
    .project-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 0.75rem;
    }

    .project-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 0.85rem 1rem;
    }

    .project-card-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.5rem;
      margin-bottom: 0.3rem;
    }

    .project-card h3 {
      margin: 0;
      font-size: 0.95rem;
      color: var(--text-primary);
    }

    .project-weeks {
      font-size: 0.72rem;
      color: var(--text-muted);
      white-space: nowrap;
    }

    .project-card p {
      margin: 0;
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.45;
    }

    /* ── Philosophy Toggle ─────────────────────────────── */
    .philosophy-toggle {
      border: 1px solid var(--border-color);
      border-radius: 8px;
      background: var(--bg-card);
    }

    .summary-title {
      cursor: pointer;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.65rem 1rem;
      margin: 0;
      border-bottom: none;
      user-select: none;
    }

    .summary-title::-webkit-details-marker {
      display: none;
    }

    .toggle-chevron {
      color: var(--text-muted);
      transition: transform 0.2s ease;
    }

    .philosophy-toggle[open] .toggle-chevron {
      transform: rotate(180deg);
    }

    .philosophy-toggle[open] .summary-title {
      border-bottom: 1px solid var(--border-color);
    }

    .philosophy-content {
      padding: 1rem;
    }

    .philosophy-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.25rem;
    }

    .philosophy-block h3 {
      margin: 0 0 0.5rem;
      font-size: 0.95rem;
      color: var(--text-primary);
    }

    .philosophy-block p {
      margin: 0.35rem 0;
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.55;
    }

    .lens-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.6rem;
      margin: 0.75rem 0;
    }

    .lens-card {
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      padding: 0.55rem 0.7rem;
    }

    .lens-card h4 {
      margin: 0 0 0.2rem;
      font-size: 0.82rem;
      color: var(--text-primary);
    }

    .lens-card p {
      margin: 0;
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    .protocol-block {
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      padding: 0.7rem 0.85rem;
      font-family: var(--font-mono, 'SF Mono', 'Fira Code', monospace);
    }

    .protocol-block p {
      font-size: 0.78rem;
      margin: 0.2rem 0;
      color: var(--text-secondary);
    }

    /* ── Responsive ────────────────────────────────────── */
    @media (max-width: 768px) {
      .week-grid {
        grid-template-columns: 1fr;
      }

      .project-grid {
        grid-template-columns: 1fr;
      }

      .resources-grid {
        grid-template-columns: 1fr;
      }

      .philosophy-grid {
        grid-template-columns: 1fr;
      }

      .lens-row {
        grid-template-columns: 1fr;
      }

      .dashboard-nav-inner {
