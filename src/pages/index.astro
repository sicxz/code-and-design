---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Icon from '../components/Icon.astro';
import { COURSE_REGISTRY } from '../lib/courseRegistry';

const courses = Object.values(COURSE_REGISTRY);
---

<BaseLayout title="code-and-design.org">
  <nav class="breadcrumb-nav">
    <div class="breadcrumb-container">
      <div class="breadcrumb">
        <span class="breadcrumb-current">Course Index</span>
      </div>
    </div>
  </nav>

  <main class="course-content two-column">
    <div class="main-content fade-in">
      <Card variant="accent" class="card-enhanced">
        <SectionHeader icon="layers" level={1} badge={{ text: 'Unified', variant: 'success' }}>
          Code + Design Course Hub
        </SectionHeader>
        <p>
          Both course sites now live in one Astro app so `code-and-design.org` can cleanly serve
          `/1/...` and `/2/...` without separate deployments fighting for the same domain.
        </p>
      </Card>

      <div class="section-divider"></div>

      <div class="course-grid">
        {courses.map((course) => (
          <Card variant="enhanced" class="card-enhanced">
            <SectionHeader icon="book" badge={{ text: course.term, variant: 'info' }}>
              {course.title}
            </SectionHeader>
            <p>{course.subtitle}</p>
            <div class="meta-grid">
              <div><strong>Students:</strong> {course.studentCount}</div>
              <div><strong>Weeks:</strong> {course.weekCount}</div>
            </div>
            <div class="course-actions">
              <a href={course.homePath} class="btn btn-start">Open Overview</a>
              <a href={course.syllabusPath} class="btn btn-secondary">Syllabus</a>
              <a href={course.assignmentsPath} class="btn btn-secondary">Assignments</a>
              <a href={course.styleGuidePath} class="btn btn-secondary">Style Guide</a>
            </div>
          </Card>
        ))}
      </div>
    </div>

    <aside class="sidebar">
      <section class="card card-enhanced">
        <h3>
          <Icon name="target" size={18} class="section-icon" />
          URL Structure
        </h3>
        <ul class="sidebar-concepts">
          <li>`/1/...` for Code + Design 1</li>
          <li>`/2/...` for Code + Design 2</li>
          <li>One shared Astro deployment for the whole domain</li>
        </ul>
      </section>
    </aside>
  </main>

  <style>
    .course-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1rem;
    }

    .meta-grid {
      display: grid;
      gap: 0.35rem;
      margin: 1rem 0;
      color: var(--text-secondary);
    }

    .course-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1rem;
    }
  </style>
</BaseLayout>
