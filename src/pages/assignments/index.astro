---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Icon from '../../components/Icon.astro';
import courseData from '../../data/course-data.json';
---

<BaseLayout title="Projects + Assignments - DESN378">
  <nav class="breadcrumb-nav">
    <div class="breadcrumb-container">
      <div class="breadcrumb">
        <a href="/">Course Overview</a>
        <span class="breadcrumb-separator">></span>
        <span class="breadcrumb-current">Projects + Assignments</span>
      </div>
    </div>
  </nav>

  <main class="course-content two-column">
    <div class="main-content fade-in">
      <Card variant="accent" class="card-enhanced">
        <SectionHeader icon="clipboard-list" level={1} badge={{ text: 'Consolidated', variant: 'success' }}>
          Projects + Assignments
        </SectionHeader>
        <p>
          This page is aligned to the Winter 2026 consolidated curriculum map.
          Weekly assignment details live on each week page, and major project docs are listed below.
        </p>
      </Card>

      <div class="section-divider"></div>

      <Card variant="enhanced">
        <SectionHeader icon="target">
          Major Projects
        </SectionHeader>
        <ul class="project-list">
          {courseData.projects.map((project) => (
            <li>
              <h3>{project.name}</h3>
              <p><strong>Brief:</strong> <code>{project.path}</code></p>
              <p><strong>Checklist:</strong> <code>{project.checklist}</code></p>
            </li>
          ))}
        </ul>
      </Card>

      <div class="section-divider"></div>

      <Card variant="accent-subtle" class="card-enhanced">
        <SectionHeader icon="calendar">
          Weekly Assignment Access
        </SectionHeader>
        <p style="margin-bottom: 0.75rem;">Use week routes for all week-by-week assignment and activity details:</p>
        <div class="week-links">
          {courseData.weeks.map((week) => (
            <a href={week.route}>Week {week.week}</a>
          ))}
        </div>
      </Card>
    </div>

    <aside class="sidebar">
      <section class="card card-enhanced">
        <h3>
          <Icon name="book" size={18} class="section-icon" />
          Canonical Sources
        </h3>
        <ul class="sidebar-concepts">
          <li>`curriculum/weeks/` for week activity files</li>
          <li>`curriculum/projects/` for project docs</li>
          <li>`docs/W26-COURSE-CONSOLIDATION-ALIGNMENT.md` for mapping</li>
        </ul>
      </section>
    </aside>
  </main>

  <style>
    .project-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.75rem;
    }

    .project-list li {
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 0.8rem 0.95rem;
    }

    .project-list h3 {
      margin-bottom: 0.4rem;
    }

    .project-list p {
      margin: 0.2rem 0;
      color: var(--text-secondary);
    }

    .project-list code {
      font-size: 0.78rem;
      word-break: break-word;
    }

    .week-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
    }

    .week-links a {
      display: inline-block;
      text-decoration: none;
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 999px;
      padding: 0.3rem 0.7rem;
      color: var(--text-link);
      font-size: 0.88rem;
    }

    .week-links a:hover {
      border-color: var(--brand-primary);
    }
  </style>
</BaseLayout>
