---
import CourseTwoGenericWeek from '../../../course-pages/course-2/weeks/GenericWeek.astro';
import CourseOneWeek from '../../../course-pages/course-1/weeks/CourseOneWeek.astro';
import {
  COURSE_ONE_WEEKS,
  getCourseOneWeek,
} from '../../../course-pages/course-1/weeks/weekRegistry';
import {
  COURSE_TWO_SPECIAL_WEEK_COMPONENTS,
  COURSE_TWO_WEEKS,
  getCourseTwoWeekData,
  type CourseTwoWeekRecord,
} from '../../../course-pages/course-2/weeks/weekRegistry';
import { isCourseId } from '../../../lib/courseRegistry';

export function getStaticPaths() {
  const courseOnePaths = COURSE_ONE_WEEKS.map((week) => ({
    params: { course: '1', week: week.key },
  }));

  const courseTwoPaths = COURSE_TWO_WEEKS.map((week) => ({
    params: { course: '2', week: `week-${week.week}` },
    props: { weekData: week },
  }));

  return [...courseOnePaths, ...courseTwoPaths];
}

const { course, week } = Astro.params;
const routeProps = Astro.props as { weekData?: CourseTwoWeekRecord };

if (!isCourseId(course)) {
  throw new Error(`Unknown course route: ${course}`);
}

let courseOneWeek = null;
let weekData = routeProps.weekData;
let WeekPage: any = null;

if (course === '1') {
  courseOneWeek = getCourseOneWeek(week);
  if (!courseOneWeek) {
    throw new Error(`Unknown Code + Design 1 week: ${week}`);
  }
} else {
  WeekPage = week ? (COURSE_TWO_SPECIAL_WEEK_COMPONENTS as Record<string, any>)[week] : null;
  weekData ??= getCourseTwoWeekData(week);

  if (!WeekPage && !weekData) {
    throw new Error(`Unknown Code + Design 2 week: ${week}`);
  }
}
---

{course === '1'
  ? <CourseOneWeek week={courseOneWeek} />
  : (WeekPage ? <WeekPage /> : <CourseTwoGenericWeek weekData={weekData} />)}
