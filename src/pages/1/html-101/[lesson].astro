---
import { LESSONS } from '../../../course-pages/course-1/html-101/lessonRegistry';
import LessonPage from '../../../course-pages/course-1/html-101/LessonPage.astro';

export function getStaticPaths() {
  return LESSONS.map((lesson) => ({
    params: { lesson: lesson.slug },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
---

<LessonPage lesson={lesson} />
