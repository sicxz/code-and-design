---
import RedirectPage from '../../components/RedirectPage.astro';
import { COURSE_TWO_WEEKS } from '../../course-pages/course-2/weeks/weekRegistry';

export function getStaticPaths() {
  return COURSE_TWO_WEEKS.map((week) => ({
    params: { week: `week-${week.week}` },
    props: { to: week.route },
  }));
}

const { to } = Astro.props as { to: string };
---

<RedirectPage to={to} title="Redirecting to the current week route" />
